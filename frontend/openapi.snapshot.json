{
  "openapi": "3.1.0",
  "info": {
    "title": "Corrigenda",
    "description": "Post-OCR text correction of ALTO/PAGE XML files using LLM providers.",
    "version": "1.0.0"
  },
  "paths": {
    "/api/providers/models": {
      "post": {
        "tags": ["providers"],
        "summary": "List Models",
        "description": "List available models for a given provider and API key.",
        "operationId": "list_models_api_providers_models_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ListModelsRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListModelsResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/jobs": {
      "post": {
        "tags": ["jobs"],
        "summary": "Create Job",
        "description": "Upload ALTO files and start a correction job.",
        "operationId": "create_job_api_jobs_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_create_job_api_jobs_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateJobResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/jobs/{job_id}": {
      "get": {
        "tags": ["jobs"],
        "summary": "Get Job",
        "description": "Poll the status of a correction job.",
        "operationId": "get_job_api_jobs__job_id__get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobStatusResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/jobs/{job_id}/cancel": {
      "post": {
        "tags": ["jobs"],
        "summary": "Cancel Job",
        "description": "Plan V2.2 \u2014 request cooperative cancellation. Idempotent.\n\nSets the job's cancellation event; the pipeline's ``should_abort``\nprobe (polled between pages and chunks) trips on the next check and\nthe runner lands the job in CANCELLED with no output promoted. A\nrequest on an already-settled job acknowledges without effect \u2014\nthe response body always carries the CURRENT status.",
        "operationId": "cancel_job_api_jobs__job_id__cancel_post",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobStatusResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/jobs/{job_id}/events": {
      "get": {
        "tags": ["jobs"],
        "summary": "Job Events",
        "description": "SSE stream of correction job events. Plan V2.4 \u2014 EventSource\ncannot set headers, so access uses the events-scoped ``?sig=``\ncredential minted at job creation (never the capability token).",
        "operationId": "job_events_api_jobs__job_id__events_get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/jobs/{job_id}/download": {
      "get": {
        "tags": ["jobs"],
        "summary": "Download Job",
        "description": "Download corrected XML file(s).",
        "operationId": "download_job_api_jobs__job_id__download_get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/jobs/{job_id}/trace": {
      "get": {
        "tags": ["jobs"],
        "summary": "Get Job Trace",
        "description": "Return the job's CorrectionReport (\u00a79) \u2014 per-line text traces.\n\nThe response IS the versioned ``CorrectionReport`` JSON (the same\ndocument persisted as ``trace.json``): ``report_version`` / ``run_id``\n(== ``job_id``) / ``total_lines`` / ``lines``. The pre-unification\n``{job_id, total_lines, lines}`` JobTrace shape is gone.",
        "operationId": "get_job_trace_api_jobs__job_id__trace_get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true,
                  "title": "Response Get Job Trace Api Jobs  Job Id  Trace Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/jobs/{job_id}/diff": {
      "get": {
        "tags": ["jobs"],
        "summary": "Get Job Diff",
        "description": "Return per-line OCR vs corrected diff data for a completed job.\n\nThin adapter: the projection lives in ``app.api.read_models.build_diff``\n(pure, unit-tested). ``get_completed_job`` already 404s on a missing\nmanifest, but an ``assert`` would disappear under ``python -O`` (bandit\nB101), so keep a real runtime guard.",
        "operationId": "get_job_diff_api_jobs__job_id__diff_get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true,
                  "title": "Response Get Job Diff Api Jobs  Job Id  Diff Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/jobs/{job_id}/layout": {
      "get": {
        "tags": ["jobs"],
        "summary": "Get Job Layout",
        "description": "Return structural layout data (blocks + lines with ALTO coordinates).\n\nThin adapter over ``app.api.read_models.build_layout`` (pure, unit-tested).",
        "operationId": "get_job_layout_api_jobs__job_id__layout_get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true,
                  "title": "Response Get Job Layout Api Jobs  Job Id  Layout Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/jobs/{job_id}/images/{image_name}": {
      "get": {
        "tags": ["jobs"],
        "summary": "Get Job Image",
        "description": "Serve a source scan image for a job. Plan V2.4 \u2014 <img> tags cannot\nset headers, so access uses the images-scoped ``?sig=`` credential\nappended by the layout endpoint (never the capability token).",
        "operationId": "get_job_image_api_jobs__job_id__images__image_name__get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          },
          {
            "name": "image_name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Image Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Body_create_job_api_jobs_post": {
        "properties": {
          "files": {
            "items": {
              "type": "string",
              "contentMediaType": "application/octet-stream"
            },
            "type": "array",
            "title": "Files"
          },
          "provider": {
            "type": "string",
            "title": "Provider"
          },
          "api_key": {
            "type": "string",
            "title": "Api Key"
          },
          "model": {
            "type": "string",
            "title": "Model"
          },
          "geometric_pairing": {
            "type": "boolean",
            "title": "Geometric Pairing",
            "default": true
          }
        },
        "type": "object",
        "required": ["files", "provider", "api_key", "model"],
        "title": "Body_create_job_api_jobs_post"
      },
      "CreateJobResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "job_token": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Job Token"
          },
          "events_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Events Url"
          }
        },
        "type": "object",
        "required": ["job_id"],
        "title": "CreateJobResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "JobStatus": {
        "type": "string",
        "enum": [
          "queued",
          "started",
          "running",
          "completed",
          "completed_with_fallbacks",
          "failed",
          "cancel_requested",
          "cancelled"
        ],
        "title": "JobStatus",
        "description": "Lifecycle state of a correction job, surfaced to API clients."
      },
      "JobStatusResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "status": {
            "$ref": "#/components/schemas/JobStatus"
          },
          "total_lines": {
            "type": "integer",
            "title": "Total Lines",
            "default": 0
          },
          "lines_modified": {
            "type": "integer",
            "title": "Lines Modified",
            "default": 0
          },
          "chunks_total": {
            "type": "integer",
            "title": "Chunks Total",
            "default": 0
          },
          "retries": {
            "type": "integer",
            "title": "Retries",
            "default": 0
          },
          "fallbacks": {
            "type": "integer",
            "title": "Fallbacks",
            "default": 0
          },
          "duration_seconds": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Duration Seconds"
          },
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          }
        },
        "type": "object",
        "required": ["job_id", "status"],
        "title": "JobStatusResponse"
      },
      "ListModelsRequest": {
        "properties": {
          "provider": {
            "$ref": "#/components/schemas/Provider"
          },
          "api_key": {
            "type": "string",
            "title": "Api Key"
          }
        },
        "type": "object",
        "required": ["provider", "api_key"],
        "title": "ListModelsRequest"
      },
      "ListModelsResponse": {
        "properties": {
          "provider": {
            "$ref": "#/components/schemas/Provider"
          },
          "models": {
            "items": {
              "$ref": "#/components/schemas/ModelInfo"
            },
            "type": "array",
            "title": "Models"
          }
        },
        "type": "object",
        "required": ["provider", "models"],
        "title": "ListModelsResponse"
      },
      "ModelInfo": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "label": {
            "type": "string",
            "title": "Label"
          },
          "supports_structured_output": {
            "type": "boolean",
            "title": "Supports Structured Output",
            "default": true
          },
          "context_window": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Context Window"
          }
        },
        "type": "object",
        "required": ["id", "label"],
        "title": "ModelInfo",
        "description": "An LLM model description as returned by ``BaseProvider.list_models``."
      },
      "Provider": {
        "type": "string",
        "enum": ["openai", "anthropic", "mistral", "google"],
        "title": "Provider",
        "description": "Identifier for an LLM vendor. Each value maps to one ``BaseProvider``."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": ["loc", "msg", "type"],
        "title": "ValidationError"
      }
    }
  }
}
